    {
        "id": "5766d8773de71925",
        "type": "function",
        "z": "157f0179e454ccd7",
        "name": "prefix",
        "func": "let data = msg.payload;\n\n// Jika payload berupa Buffer, ubah ke string\nif (Buffer.isBuffer(data)) {\n    data = data.toString(\"utf8\");\n}\n\n// Jika bukan string, tetap ubah ke string\ndata = String(data);\n\n// Hilangkan enter bawaan dari serial, agar format tidak rusak\ndata = data.replace(/[\\r\\n]+$/g, \"\");\n\n// Tambahkan format awalan dan akhiran\nmsg.payload = `ext_tps,${data},~\\n`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 2665,
        "wires": [
            []
        ]
    },
